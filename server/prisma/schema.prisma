generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id               Int           @id @default(autoincrement())
  kunnr            String        @unique @db.VarChar(10)
  nombre           String        @db.VarChar(100)
  rut              String        @db.VarChar(20)
  condicion_pago   String        @default("CONT") @db.VarChar(20)
  estado_credito   EstadoCredito @default(AL_DIA)
  credito_asignado Int           @default(0)
  credito_utilizado Int          @default(0)
  sucursal         String        @default("D190") @db.VarChar(10)
  createdAt        DateTime      @default(now())

  // Datos generales del cliente (SAP maestro deudor)
  tratamiento           String?  @db.VarChar(20)
  nombre2               String?  @db.VarChar(100)
  concepto_busqueda     String?  @db.VarChar(50)
  giro                  String?  @db.VarChar(100)
  direccion             String?  @db.VarChar(200)
  region                String?  @db.VarChar(50)
  ciudad                String?  @db.VarChar(50)
  comuna                String?  @db.VarChar(50)
  zona_transporte       String?  @db.VarChar(50)
  telefono              String?  @db.VarChar(20)
  celular               String?  @db.VarChar(20)
  fax                   String?  @db.VarChar(20)
  direccion_postal      String?  @db.VarChar(200)
  ciudad_postal         String?  @db.VarChar(50)
  casilla               String?  @db.VarChar(50)
  correo_contacto       String?  @db.VarChar(100)
  correo_factura        String?  @db.VarChar(100)

  // Ficha del cliente (SAP FD32 / maestro deudor)
  razon_social              String?  @db.VarChar(200)
  clasificacion_comercial   String?  @db.VarChar(50)
  representante_legal       String?  @db.VarChar(100)
  seguro                    String?  @db.VarChar(50)
  grupo_control_credito     String?  @db.VarChar(10)

  @@map("clientes")
}

model Material {
  id              Int      @id @default(autoincrement())
  matnr           String   @unique @db.VarChar(18)
  descripcion     String   @db.VarChar(200)
  precio_unitario Int
  unidad_medida   String   @default("UN") @db.VarChar(5)
  bloqueado       Boolean  @default(false)
  createdAt       DateTime @default(now())

  stocks Stock[]

  @@map("materiales")
}

model Stock {
  id       Int    @id @default(autoincrement())
  matnr    String @db.VarChar(18)
  centro   String @db.VarChar(10)
  almacen  String @db.VarChar(10)
  cantidad Int    @default(0)

  material Material @relation(fields: [matnr], references: [matnr])

  @@unique([matnr, centro, almacen])
  @@map("stock")
}

model PartidaAbierta {
  id         Int           @id @default(autoincrement())
  belnr      String        @unique @db.VarChar(10)
  kunnr      String        @db.VarChar(10)
  vbeln      String?       @db.VarChar(10)
  clase_doc  String        @default("FV") @db.VarChar(5)
  fecha_doc  DateTime
  fecha_venc DateTime
  importe    Int
  estado     EstadoPartida @default(ABIERTO)
  dias_mora  Int           @default(0)

  @@map("partidas_abiertas")
}

model PedidoVenta {
  id        Int      @id @default(autoincrement())
  vbeln     String   @unique @db.VarChar(10)
  kunnr     String   @db.VarChar(10)
  fecha     DateTime @default(now())
  tipo_doc  String   @default("ZPOS") @db.VarChar(50)
  canal     String   @default("Venta Meson") @db.VarChar(50)
  estado           String   @default("Creado") @db.VarChar(20)
  total            Int      @default(0)
  belnr_cobro      String?  @db.VarChar(10)
  observaciones    String?  @db.VarChar(500)
  ubicacion_predio String?  @db.VarChar(1000)
  createdAt        DateTime @default(now())

  posiciones PedidoPosicion[]

  @@map("pedidos_venta")
}

model PedidoPosicion {
  id              Int    @id @default(autoincrement())
  vbeln           String @db.VarChar(10)
  matnr           String @db.VarChar(18)
  cantidad        Int
  precio_unitario Int
  subtotal        Int

  pedido PedidoVenta @relation(fields: [vbeln], references: [vbeln])

  @@map("pedidos_posicion")
}

model Cobro {
  id         Int      @id @default(autoincrement())
  belnr      String   @unique @db.VarChar(10)
  kunnr      String   @db.VarChar(10)
  fecha      DateTime @default(now())
  monto      Int
  medio_pago String   @default("EFECTIVO") @db.VarChar(30)
  clase_doc  String   @default("W") @db.VarChar(5)
  createdAt  DateTime @default(now())

  @@map("cobros")
}

enum EstadoCredito {
  BLOQUEADO
  AL_DIA
  CON_DEUDA
}

enum EstadoPartida {
  ABIERTO
  VENCIDO
  PAGADO
}
