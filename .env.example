# .env.example — Cooprinsem POS
# Copiar a .env.development (desarrollo con mocks) y .env.production (SAP real)
# NUNCA commitear archivos .env con valores reales al repositorio

# =========================================================
# SAP S/4HANA — Conexión OData
# =========================================================

# URL base del servidor SAP (sin slash final)
# DEV: servidor QAS de pruebas
# PROD: servidor PRD de producción
VITE_SAP_ODATA_BASE_URL=https://sapqas.cooprinsem:44320/sap/opu/odata/sap

# Sociedad SAP de Cooprinsem — CONFIRMADO
VITE_SAP_SOCIEDAD=COOP

# SAP Client Number — PENDIENTE confirmar con equipo ABAP
VITE_SAP_CLIENT=

# Organización de Ventas — PENDIENTE confirmar con equipo ABAP
VITE_SAP_ORG_VENTAS=

# Canal de Distribución (código numérico) — PENDIENTE confirmar con equipo ABAP
VITE_SAP_CANAL_DIST=

# Sector / División SAP — PENDIENTE confirmar con equipo ABAP
VITE_SAP_SECTOR=

# =========================================================
# Mocks de desarrollo (MSW)
# =========================================================

# true = MSW intercepta todas las llamadas OData (desarrollo sin SAP)
# false = llamadas reales a SAP (producción / testing con SAP QAS)
VITE_USE_MOCK=true

# =========================================================
# Nombres de servicios OData — PENDIENTE confirmar con equipo ABAP
# Los nombres exactos los define el equipo ABAP al publicar el servicio
# =========================================================
VITE_ODATA_SERVICE_VENTAS=ZPOSSalesService
VITE_ODATA_SERVICE_PAGOS=ZPOSPaymentService
VITE_ODATA_SERVICE_CLIENTES=ZPOSCustomerService
VITE_ODATA_SERVICE_MATERIALES=ZPOSMaterialService

# =========================================================
# App
# =========================================================
VITE_APP_TITLE=Cooprinsem POS
VITE_APP_VERSION=0.1.0-poc
